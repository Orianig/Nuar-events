---
import AboutNuarPage from '../../components/pages/AboutNuarPage.astro';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };
const langSafe: Lang = lang === 'en' ? 'en' : 'es';
const base = import.meta.env.BASE_URL;
---

<AboutNuarPage lang={langSafe} currentPath={Astro.url.pathname} base={base} />
