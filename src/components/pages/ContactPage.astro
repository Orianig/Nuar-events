---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../layout/Navbar.astro';
import Footer from '../layout/Footer.astro';
import { getTranslations, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
  currentPath: string;
  base: string;
}

const { lang, currentPath, base } = Astro.props as Props;
const t = getTranslations(lang);
const p = t.pages.contact;
const baseSlash = base.endsWith('/') ? base : `${base}/`;
const homeHref = lang === 'en' ? `${baseSlash}en/` : `${baseSlash}`;
const projectsHref = lang === 'en' ? `${baseSlash}en/projects` : `${baseSlash}projects`;
const pageDescription =
  lang === 'en'
    ? 'Contact Nuar Events to design meaningful celebrations from start to finish.'
    : 'Contacta con Nuar Events para disenar experiencias y celebraciones cuidadas de principio a fin.';
---

<Layout title={p.title} description={pageDescription} lang={lang} currentPath={currentPath}>
  <Navbar
    currentPath={currentPath}
    brandName={t.nav.brandName}
    home={t.nav.home}
    projects={t.nav.projects}
    aboutNuar={t.nav.aboutNuar}
    upcomingEvents={t.nav.upcomingEvents}
    contact={t.nav.contact}
    menuToggle={t.nav.menuToggle}
    currentLang={lang}
    base={base}
  />
  <div class="min-h-screen flex flex-col items-center justify-center bg-stone pt-24 pb-8 px-8">
    <div class="text-center flex flex-col gap-8">
      <h1 class="text-4xl font-bold text-gray-800">{p.heading}</h1>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={homeHref} class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium shadow-md">
          {p.goHome}
        </a>
        <a href={projectsHref} class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium shadow-md">
          {p.goProjects}
        </a>
      </div>
    </div>
  </div>
  <Footer contactText={t.footer.contact} currentLang={lang} base={base} />
</Layout>
