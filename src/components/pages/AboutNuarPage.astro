---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../layout/Navbar.astro';
import Footer from '../layout/Footer.astro';
import { getTranslations, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
  currentPath: string;
  base: string;
}

const { lang, currentPath, base } = Astro.props as Props;
const t = getTranslations(lang);
const p = t.pages.aboutNuar;
const sectionOne = p.whatIsNuar;
const sectionTwo = p.originStory;
---

<Layout title={p.title} description={p.description} lang={lang} currentPath={currentPath}>
  <Navbar
    currentPath={currentPath}
    brandName={t.nav.brandName}
    home={t.nav.home}
    projects={t.nav.projects}
    aboutNuar={t.nav.aboutNuar}
    upcomingEvents={t.nav.upcomingEvents}
    contact={t.nav.contact}
    menuToggle={t.nav.menuToggle}
    currentLang={lang}
    base={base}
  />
  <main class="bg-stone flex flex-col text-base">
    <div class="w-full flex flex-col md:flex-row gap-6 p-6 md:p-10 pt-[96px] md:pt-[100px]">
<div class="w-full md:w-[55%] text-bark md:pr-8">
  <div class="w-full flex flex-col gap-5">
    <div class="flex items-start">
      <div>
      <p class="font-title  text-2xl md:text-4xl">{sectionOne.kicker}</p>
      <h1 class="font-title text-6xl md:text-8xl leading-none">{p.title}</h1>
      </div>
      <img
        src="/icons/leaf1.png"
        alt=""
        aria-hidden="true"
        class="w-20 h-20 md:w-28 md:h-28 opacity-50"
      />
    </div>

    <div class="font-semibold text-base md:text-lg leading-relaxed">
      <p>{sectionOne.hero.lineOne}</p>
      <p>{sectionOne.hero.lineTwo}</p>
    </div>

    <div class="flex flex-col font-normal gap-4 text-lg leading-relaxed w-[90%]">
      {sectionOne.intro.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>

    <div class="flex w-full flex-col items-center gap-6 pt-4 md:flex-row md:items-stretch md:gap-x-8 md:justify-between">
      {sectionOne.pillars.map((pillar) => (
        <div class="flex w-[88%] max-w-[320px] flex-col items-center gap-y-2 rounded-2xl bg-stone-dark/20 p-4 text-center md:w-full md:max-w-[220px] md:items-start md:rounded-none md:bg-transparent md:p-0 md:text-left">
            <img src={pillar.icon} alt="" aria-hidden="true" class="w-10 h-10 object-contain" />
          <p class="font-bold text-lg">{pillar.title}</p>
          <p class=" text-base leading-relaxed">{pillar.description}</p>
        </div>
      ))}
    </div>

    <p class="py-4 text-base leading-relaxed md:w-[80%]">{sectionOne.real}</p>

    <div class="flex items-start md:w-[90%]">
      <img
        src="/icons/leaf2.png"
        alt=""
        aria-hidden="true"
        class="w-14 h-14 md:w-20 md:h-20 object-contain shrink-0 mt-6 -mr-2 md:-mr-4 opacity-50"
      />
      <div class="rounded-xl bg-stone-dark/40 p-4 md:p-5 w-full">
        <p class="text-base leading-relaxed">{sectionOne.customEvents.lineOne}</p>
        <p class="text-base leading-relaxed">{sectionOne.customEvents.lineTwo}</p>
      </div>
    </div>

    <div class="flex flex-col gap-1 text-base leading-relaxed">
      {sectionOne.closing.lines.map((line) => (
        <p>{line}</p>
      ))}
      {sectionOne.closing.strong.map((line) => (
        <p class="font-semibold">{line}</p>
      ))}
    </div>
  </div>
</div>
  <div class="relative mt-2 flex w-full justify-center overflow-hidden md:mt-0 md:w-[45%] md:min-h-[720px] md:justify-start md:overflow-visible">
    <img
      src="/collage.png"
      alt=""
      aria-hidden="true"
      class="relative w-[120%] max-w-none -translate-x-[5%] object-contain object-center md:absolute md:right-0 md:top-[12%] md:w-[130%] md:max-w-none md:translate-x-0"
      loading="lazy"
      decoding="async"
    />
  </div>
    </div>      
    
    <div class="w-full flex flex-col md:flex-row gap-8 p-6 md:p-10 bg-olive-light/40">
      <div class="w-full md:w-[60%] text-bark">
        <div class="w-full flex flex-col">
          <div class="relative inline-flex w-fit flex-col overflow-visible px-5 py-3 md:px-16 md:py-4">
            <img
              src="/PaperEf.png"
              alt=""
              aria-hidden="true"
              class="absolute inset-0 h-[105%] w-full object-fill -translate-x-[3%] about-paper-stretch-x"
              loading="lazy"
              decoding="async"
            />
            <p class="relative z-10 font-title text-2xl md:text-3xl">{sectionTwo.kicker}</p>
            <h2 class="relative z-10 font-title text-6xl md:text-7xl">{sectionTwo.title}</h2>
          </div>

          <div class="relative pt-4 pl-5 flex flex-col gap-5">
            <div
              aria-hidden="true"
              class="about-origin-timeline-line absolute left-[27px] top-0 bottom-3 w-[2px]"
            ></div>
            {sectionTwo.blocks.map((block, idx) => {
              const icon = block.icon ?? '/icons/leaf.png';
              return (
                <div class="flex items-start gap-3 md:gap-4">
                  <div class="relative w-6 md:w-7 shrink-0 pt-2">
                    <span class="absolute left-[8px] top-[14px] -translate-x-1/2 h-2 w-2 rounded-full bg-bark"></span>
                  </div>
                  <img src={icon} alt="" aria-hidden="true" class="w-6 h-6 md:w-9 md:h-9 object-contain shrink-0 mt-2" />
                  <div class="text-base leading-relaxed md:leading-loose">
                    {block.lines?.map((line, lineIdx) => {
                      const isLastLine = lineIdx === block.lines!.length - 1;
                      if (block.highlight && isLastLine) {
                        return (
                          <p>
                            {line}
                            <span class="font-semibold">{block.highlight}</span>
                          </p>
                        );
                      }
                      return <p>{line}</p>;
                    })}
                    {block.highlight && !block.lines?.length && (
                      <p class="font-semibold">{block.highlight}</p>
                    )}
                    {block.paragraph && <p>{block.paragraph}</p>}
                    {block.linesAfter?.map((line) => (
                      <p>{line}</p>
                    ))}
                    {block.closing?.map((line) => (
                      <p>{line}</p>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
      <div class="w-full md:w-[40%] min-h-[720px] rounded-[28px] bg-blue-300"></div>
    </div>
  </main>
  <Footer contactText={t.footer.contact} currentLang={lang} base={base} />
</Layout>

