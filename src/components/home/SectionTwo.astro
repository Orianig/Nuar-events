---
import type { SectionTwoProps } from '../../types';

const { sectionTitle, items = [], backgroundColor } = Astro.props as SectionTwoProps;
---

<section class={`py-12 md:py-20 ${backgroundColor ?? 'bg-bark'}`}>
  <div class="container mx-auto px-6 max-w-6xl">
    {sectionTitle && (
      <h2 class="font-title text-3xl md:text-4xl font-semibold text-center text-stone mb-12">
        {sectionTitle}
      </h2>
    )}

    <!-- Desktop: 3 columnas -->
    <div class="hidden md:grid gap-8 md:grid-cols-3 md:justify-items-center">
      {items.map((item) => (
        <article class="section-two-panel w-full md:max-w-[320px]">
          <div class="section-two-panel-content">
            <h3 class="font-title text-2xl text-stone mb-4 leading-snug">
              {item.title}
            </h3>
            <div class="section-two-divider" />
            <p class="font-body text-stone/80 text-sm leading-relaxed">
              {item.description}
            </p>
          </div>
        </article>
      ))}
    </div>

    <!-- Mobile: carrusel con tres puntitos -->
    <div id="section-two-carousel" class="md:hidden overflow-hidden">
      <div
        id="section-two-track"
        class="flex transition-transform duration-300 ease-out"
        style="width: 300%"
      >
        {items.map((item, i) => (
          <div class="w-1/3 shrink-0 px-1" role="tabpanel" id={`section-two-panel-${i}`} aria-labelledby={`section-two-tab-${i}`}>
            <article class="section-two-panel">
              <div class="section-two-panel-content">
                <h3 class="font-title text-xl text-stone mb-3 leading-snug">
                  {item.title}
                </h3>
                <div class="section-two-divider" />
                <p class="font-body text-stone/80 text-sm leading-relaxed">
                  {item.description}
                </p>
              </div>
            </article>
          </div>
        ))}
      </div>
      <div
        id="section-two-dots"
        class="flex justify-center gap-2 mt-8 pb-2"
        role="tablist"
        aria-label="Seleccionar panel"
      >
        {items.map((_, i) => (
          <button
            type="button"
            class="section-two-dot w-2.5 h-2.5 rounded-full border-2 border-stone/60 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-stone/50"
            data-index={i}
            id={`section-two-tab-${i}`}
            role="tab"
            aria-controls={`section-two-panel-${i}`}
            aria-label={`Panel ${i + 1}`}
            aria-selected={i === 0}
            tabindex={i === 0 ? 0 : -1}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const track = document.getElementById('section-two-track');
    const dotsContainer = document.getElementById('section-two-dots');
    if (!track || !dotsContainer) return;
    const trackEl = track;

    const dots = dotsContainer.querySelectorAll('.section-two-dot');
    const total = dots.length;
    if (total === 0) return;

    let index = 0;
    function goTo(i: number) {
      index = Math.max(0, Math.min(i, total - 1));
      trackEl.style.transform = `translateX(-${index * (100 / 3)}%)`;
      dots.forEach((dot, j) => {
        dot.setAttribute('aria-selected', String(j === index));
        dot.setAttribute('tabindex', j === index ? '0' : '-1');
      });
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goTo(i));
    });

    let startX = 0;
    trackEl.addEventListener(
      'touchstart',
      (e) => {
        startX = e.touches[0].clientX;
      },
      { passive: true }
    );
    trackEl.addEventListener(
      'touchend',
      (e) => {
        const endX = e.changedTouches[0].clientX;
        const diff = startX - endX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) goTo(index + 1);
          else goTo(index - 1);
        }
      },
      { passive: true }
    );

    goTo(0);
  })();
</script>
