---
import type { SectionThreeProps } from '../../types';

const { centerText, backgroundColor } = Astro.props as SectionThreeProps;
const [firstLine = '', ...restWords] = (centerText ?? '').trim().split(/\s+/);
const secondLine = restWords.join(' ');
---

<section class={`relative  ${backgroundColor ?? 'bg-sand'} overflow-hidden`}>
  <div class="relative w-full">
    <!-- Desktop -->
    <div class="relative hidden md:block overflow-hidden py-8">
      <div class="relative w-full h-[480px] lg:h-[540px] xl:h-[580px]">
        <img
          src="/SectionThree-BgGr-Desktop.svg"
          alt=""
          aria-hidden="true"
          width="1920"
          height="1080"
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-[113%] w-full m-auto object-cover object-center"
        />
        <img
          src="/SectionThree-Bg-Desktop.svg"
          alt=""
          aria-hidden="true"
          width="1920"
          height="1080"
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-[106%] w-full m-auto object-contain object-center"
        />
        <div class="absolute inset-0 flex items-center justify-center">
          <img
            src="/SectionThree-Center-Desktop.svg"
            alt=""
            aria-hidden="true"
            width="1920"
            height="1080"
            loading="lazy"
            decoding="async"
            class="absolute left-1/2 top-[54%] h-[82%] w-[82%] -translate-x-1/2 -translate-y-1/2 object-contain object-center"
          />
          <div class="absolute left-1/2 top-4 -translate-x-1/2 text-center font-title text-olive-dark leading-none">
            <h2 class="block text-2xl lg:text-3xl">{firstLine}</h2>
            <span class="block text-5xl lg:text-5xl">{secondLine}</span>
          </div>
          <div class="sr-only">
            <h2>
              {centerText}
            </h2>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile -->
    <div class="relative md:hidden">
      <img
        src="/SectionThree-Bg-mobile.svg"
        alt=""
        aria-hidden="true"
        width="900"
        height="1200"
        loading="lazy"
        decoding="async"
        class="w-full h-auto"
      />
      <h2
        class="absolute inset-x-0 top-[8%] flex flex-col items-center text-center font-title text-olive-dark leading-none px-6"
      >
        <span class="block text-[clamp(1.4rem,5.6vw,1.8rem)]">{firstLine}</span>
        <span class="block text-[clamp(2.9rem,11vw,3.5rem)]">{secondLine}</span>
      </h2>
      <div class="absolute inset-0 flex items-center justify-center px-4">
        <div class="relative w-[84%] max-w-[360px]">
          <img
            src="/SectionThree-Center-Mobile.svg"
            alt=""
            aria-hidden="true"
            width="330"
            height="330"
            loading="lazy"
            decoding="async"
            class="w-full h-auto"
          />
        </div>
      </div>
    </div>
  </div>
</section>
