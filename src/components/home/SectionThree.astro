---
import type { SectionThreeProps } from '../../types';

const { centerText, backgroundColor } = Astro.props as SectionThreeProps;
const [firstLine = '', ...restWords] = (centerText ?? '').trim().split(/\s+/);
const secondLine = restWords.join(' ');
---

<section class={`relative  ${backgroundColor ?? 'bg-sand'} overflow-hidden`}>
  <div class="relative w-full">
    <!-- Desktop -->
    <div class="relative hidden md:block overflow-hidden py-8">
      <div class="relative w-full h-[480px] lg:h-[540px] xl:h-[580px]">
        <img
          src="/SectionThree-BgGr-Desktop.svg"
          alt=""
          aria-hidden="true"
          width="1920"
          height="1080"
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-[113%] w-full m-auto object-cover object-center"
        />
        <div
          aria-hidden="true"
          class="absolute inset-0 w-full h-full"
          style="background-image: url('/SectionThree-Bg-Desktop.svg'); background-size: 100% 100%; background-repeat: no-repeat;"
        ></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <img
            src="/SectionThree-Center-Desktop.svg"
            alt=""
            aria-hidden="true"
            width="1920"
            height="1080"
            loading="lazy"
            decoding="async"
            class="absolute left-1/2 top-[54%] h-[82%] w-[82%] -translate-x-1/2 -translate-y-1/2 object-contain object-center"
          />
          <div class="absolute left-1/2 top-4 -translate-x-1/2 text-center font-title text-olive-dark leading-none">
            <h2 class="block text-2xl lg:text-3xl">{firstLine}</h2>
            <span class="block text-5xl lg:text-5xl">{secondLine}</span>
          </div>
          <div class="sr-only">
            <h2>
              {centerText}
            </h2>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile -->
    <div class="relative md:hidden overflow-hidden py-2">
      <div class="relative w-full h-[620px] sm:h-[700px]">
        <img
          src="/SectionThree-BgGr-mobile.png"
          alt=""
          aria-hidden="true"
          width="900"
          height="1200"
          loading="lazy"
          decoding="async"
          class="absolute inset-0 z-10 h-[108%] w-full m-auto object-cover object-center"
        />
        <div
          aria-hidden="true"
          class="absolute inset-0 z-0 h-full w-full"
          style="background-image: url('/SectionThree-Bg-mobile.png'); background-size: 100% 100%; background-repeat: no-repeat;"
        ></div>
        <div class="absolute inset-0 z-20 flex items-center justify-center">
          <img
            src="/SectionThree-Center-Mobile.png"
            alt=""
            aria-hidden="true"
            width="900"
            height="1200"
            loading="lazy"
            decoding="async"
            class="absolute left-1/2 top-[56%] h-[78%] w-[78%] -translate-x-1/2 -translate-y-1/2 object-contain object-center"
          />
          <h2
            class="absolute inset-x-0 top-[3%] flex flex-col items-center text-center font-title text-olive-dark leading-none px-6"
          >
            <span class="block text-[1.75rem]">{firstLine}</span>
            <span class="block text-[3.4rem]">{secondLine}</span>
          </h2>
        </div>
      </div>
    </div>
  </div>
</section>
