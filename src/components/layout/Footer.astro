---
import type { FooterProps } from '../../types';

const { contactText, currentLang = 'es', base = '' } = Astro.props as FooterProps;
const b = base.endsWith('/') ? base.slice(0, -1) : base;
const hrefContact = currentLang === 'en' ? (b ? `${b}/en/contact` : '/en/contact') : (b ? `${b}/contact` : '/contact');
---

<footer class="bg-stone py-8 border-t border-bark/20">
  <div class="container mx-auto px-6 text-center">

    <div class="mt-5 flex items-center justify-center gap-3" aria-label="Redes sociales Nuar Events">
      <a
        href="https://www.instagram.com/nuarevents/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram de Nuar Events"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-olive-dark text-stone transition-opacity hover:opacity-85"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
          <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5a4.25 4.25 0 0 0 4.25 4.25h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5a4.25 4.25 0 0 0-4.25-4.25h-8.5ZM17.5 6.6a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z" />
        </svg>
      </a>
      <a
        href="https://www.tiktok.com/@nuareventss"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="TikTok de Nuar Events"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-olive-dark text-stone transition-opacity hover:opacity-85"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
          <path d="M14.3 3h2.8c.2 1.3.9 2.4 2 3.1.7.4 1.4.7 2.2.8v2.9a8.7 8.7 0 0 1-4.2-1.2v5.7a6.3 6.3 0 1 1-6.3-6.3c.4 0 .8 0 1.2.1V11a3.5 3.5 0 1 0 2.3 3.3V3Z" />
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/company/nuar-events/posts/?feedView=all"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn de Nuar Events"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-olive-dark text-stone transition-opacity hover:opacity-85"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
          <path d="M6.4 8.2a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6ZM4.9 9.8h3v9.3h-3V9.8Zm4.9 0h2.9v1.3h.1c.4-.8 1.4-1.6 3-1.6 3.2 0 3.8 2.1 3.8 4.8v4.8h-3v-4.3c0-1 0-2.4-1.5-2.4s-1.7 1.1-1.7 2.3v4.4h-3V9.8Z" />
        </svg>
      </a>
    </div>
  </div>
</footer>
