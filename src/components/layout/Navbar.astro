---
import type { NavbarProps } from '../../types';
import LangSwitcher from './LangSwitcher.astro';

const {
  brandName,
  home,
  projects,
  aboutNuar,
  upcomingEvents,
  contact,
  menuToggle,
  currentLang = 'es',
  currentPath = '/',
  base = '',
} = Astro.props as NavbarProps;
const b = base.endsWith('/') ? base.slice(0, -1) : base;
const isSpanish = currentLang === 'es';
const hrefHome = isSpanish ? (b ? `${b}/` : '/') : (b ? `${b}/en/` : '/en/');
const hrefProjects = isSpanish ? (b ? `${b}/projects` : '/projects') : (b ? `${b}/en/projects` : '/en/projects');
const hrefAboutNuar = isSpanish ? (b ? `${b}/about-nuar` : '/about-nuar') : (b ? `${b}/en/about-nuar` : '/en/about-nuar');
const hrefUpcomingEvents = `${hrefProjects}#upcoming-events`;
const hrefContact = isSpanish ? (b ? `${b}/contact` : '/contact') : (b ? `${b}/en/contact` : '/en/contact');
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-45 bg-stone/55 border-b border-transparent transition-all duration-300">
  <div class="container mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <a href={hrefHome} class="text-2xl font-bold text-bark hover:opacity-80 transition-opacity">
        {brandName}
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href={hrefHome} class="text-bark hover:opacity-80 font-medium transition-opacity">
          {home}
        </a>
        <div class="relative group events-dropdown">
          <button
            type="button"
            class="events-trigger inline-flex items-center gap-1 text-bark hover:opacity-80 font-medium transition-opacity cursor-pointer"
            aria-haspopup="true"
            aria-expanded="false"
          >
            {projects}
            <svg class="events-chevron w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="events-menu hidden absolute left-1/2 top-full z-20 mt-2 w-48 -translate-x-1/2 rounded-2xl border border-bark/20 bg-stone/95 p-2 shadow-lg backdrop-blur">
            <a href={hrefAboutNuar} class="block rounded-xl px-3 py-2 text-sm text-bark hover:bg-bark/10 transition-colors">
              {aboutNuar}
            </a>
            <a href={hrefProjects} class="block rounded-xl px-3 py-2 text-sm text-bark hover:bg-bark/10 transition-colors">
              {projects}
            </a>
            <a href={hrefUpcomingEvents} class="block rounded-xl px-3 py-2 text-sm text-bark hover:bg-bark/10 transition-colors">
              {upcomingEvents}
            </a>
          </div>
        </div>
        <a href={hrefContact} class="text-bark hover:opacity-80 font-medium transition-opacity">
          {contact}
        </a>
        <LangSwitcher currentLang={currentLang} currentPath={currentPath} />
      </div>

      <button 
        id="mobile-menu-button"
        class="md:hidden text-bark hover:opacity-80 transition-opacity"
        aria-label={menuToggle}
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pt-4 pb-2">
      <div class="flex flex-col gap-4 items-center">
        <a href={hrefHome} class="text-bark hover:opacity-80 font-medium transition-opacity">
          {home}
        </a>
        <div class="w-full max-w-[220px]">
          <button
            id="mobile-events-button"
            type="button"
            class="w-full inline-flex items-center justify-center gap-1 text-bark hover:opacity-80 font-medium transition-opacity cursor-pointer"
            aria-expanded="false"
          >
            {projects}
            <svg id="mobile-events-chevron" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="mobile-events-menu" class="hidden mt-3 flex-col items-center gap-3 text-center">
            <a href={hrefAboutNuar} class="text-bark/85 hover:opacity-80 text-sm transition-opacity">
              {aboutNuar}
            </a>
            <a href={hrefProjects} class="text-bark/85 hover:opacity-80 text-sm transition-opacity">
              {projects}
            </a>
            <a href={hrefUpcomingEvents} class="text-bark/85 hover:opacity-80 text-sm transition-opacity">
              {upcomingEvents}
            </a>
          </div>
        </div>
        <a href={hrefContact} class="text-bark hover:opacity-80 font-medium transition-opacity">
          {contact}
        </a>
        <LangSwitcher currentLang={currentLang} currentPath={currentPath} />
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const eventsTrigger = document.querySelector('.events-trigger') as HTMLButtonElement | null;
  const eventsMenu = document.querySelector('.events-menu') as HTMLElement | null;
  const eventsChevron = document.querySelector('.events-chevron') as SVGElement | null;
  const mobileEventsButton = document.getElementById('mobile-events-button') as HTMLButtonElement | null;
  const mobileEventsMenu = document.getElementById('mobile-events-menu');
  const mobileEventsChevron = document.getElementById('mobile-events-chevron');

  function updateNavOnScroll() {
    if (window.scrollY > 20) {
      nav?.classList.add('nav-scrolled');
    } else {
      nav?.classList.remove('nav-scrolled');
    }
  }

  window.addEventListener('scroll', updateNavOnScroll, { passive: true });
  updateNavOnScroll();

  menuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  eventsTrigger?.addEventListener('click', (e) => {
    e.preventDefault();
    const isHidden = eventsMenu?.classList.toggle('hidden');
    eventsTrigger.setAttribute('aria-expanded', isHidden ? 'false' : 'true');
    eventsChevron?.classList.toggle('rotate-180', !isHidden);
  });

  document.addEventListener('click', (e) => {
    const inside = (e.target as Node)?.parentElement?.closest('.events-dropdown');
    if (!inside) {
      eventsMenu?.classList.add('hidden');
      eventsTrigger?.setAttribute('aria-expanded', 'false');
      eventsChevron?.classList.remove('rotate-180');
    }
  });

  mobileEventsButton?.addEventListener('click', () => {
    const isHidden = mobileEventsMenu?.classList.toggle('hidden');
    mobileEventsMenu?.classList.toggle('flex', !isHidden);
    mobileEventsButton.setAttribute('aria-expanded', isHidden ? 'false' : 'true');
    mobileEventsChevron?.classList.toggle('rotate-180', !isHidden);
  });

  document.addEventListener('click', (e) => {
    if (!mobileMenu || !menuButton) return;
    const target = e.target as Node;
    const clickedInsideMenu = mobileMenu.contains(target);
    const clickedToggleButton = menuButton.contains(target);
    if (window.innerWidth < 768 && !clickedInsideMenu && !clickedToggleButton) {
      mobileMenu.classList.add('hidden');
      mobileEventsMenu?.classList.add('hidden');
      mobileEventsMenu?.classList.remove('flex');
      mobileEventsButton?.setAttribute('aria-expanded', 'false');
      mobileEventsChevron?.classList.remove('rotate-180');
    }
  });
</script>
